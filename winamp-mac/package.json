{
  "name": "retroamp-mac",
  "version": "1.0.0",
  "description": "RetroAmp — a classic-style player for macOS, built with Electron and Webamp.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac"
  },
  "keywords": [
    "winamp",
    "electron",
    "macos",
    "music-player"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "webamp": "^2.3.1"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.adityzkr.retroamp",
    "productName": "RetroAmp",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/webamp/built/webamp.butterchurn-bundle.min.mjs"
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
